# ── MK Customer App — Environment Variables ──────────────────
# Copy to .env and fill in values

# API (Android emulator uses 10.0.2.2, iOS simulator uses localhost)
API_URL=http://10.0.2.2:5000/api/v1
SOCKET_URL=http://10.0.2.2:5000

# Production
# API_URL=https://api.mkapp.in/api/v1
# SOCKET_URL=https://api.mkapp.in

# Google Maps (from Google Cloud Console)
GOOGLE_MAPS_API_KEY=AIzaSy...

# Razorpay (public test key)
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXX
