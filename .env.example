# ============================================================
# MK App — Environment Variables
# Copy to .env and fill in your values
# ============================================================

# ── App ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── Database ─────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/mk_app
# Docker:
# MONGO_URI=mongodb://admin:mkapp_secret_2026@mongodb:27017/mk_app?authSource=admin
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=mkapp_secret_2026

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# With password:
# REDIS_URL=redis://:mkredis_secret@localhost:6379
# Docker:
# REDIS_URL=redis://:mkredis_secret@redis:6379
REDIS_PASSWORD=mkredis_secret

# ── JWT ──────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_STRING
JWT_REFRESH_SECRET=REPLACE_WITH_ANOTHER_64_CHAR_RANDOM_STRING
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ── Razorpay ─────────────────────────────────────────────────
# Get from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Twilio (SMS OTP) ─────────────────────────────────────────
# Get from: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_AUTH_TOKEN=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX
# Static OTP for dev (remove in production!)
OTP_STATIC=1234

# ── Email (Nodemailer) ────────────────────────────────────────
EMAIL_USER=your@gmail.com
EMAIL_PASS=your_app_specific_password
EMAIL_FROM=MK App <noreply@mkapp.in>

# ── Firebase (Push Notifications) ────────────────────────────
# From: Firebase Console → Project Settings → Service Accounts
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY_ID=abc123
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=123456789
FIREBASE_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk...
# OR pass as JSON string:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ── Google Maps ───────────────────────────────────────────────
GOOGLE_MAPS_KEY=AIzaSy...

# ── Cloudinary (image uploads) ───────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=123456789
CLOUDINARY_API_SECRET=your_api_secret

# ── Frontend URLs (CORS whitelist) ───────────────────────────
FRONTEND_URLS=http://localhost:3000,https://yourdomain.com

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=200

# ── Mongo Express (dev UI) ────────────────────────────────────
ME_USERNAME=admin
ME_PASSWORD=admin

# ── Domain (for nginx) ───────────────────────────────────────
DOMAIN=yourdomain.com

# ============================================================
# REACT FRONTEND (.env in frontend/)
# ============================================================
REACT_APP_API_URL=http://localhost:5000/api/v1
REACT_APP_SOCKET_URL=http://localhost:5000

# Firebase (public — safe to commit)
REACT_APP_FIREBASE_API_KEY=AIzaSy...
REACT_APP_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your-project-id
REACT_APP_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=123456789
REACT_APP_FIREBASE_APP_ID=1:123:web:abc123
REACT_APP_FIREBASE_VAPID_KEY=BNj... # From Firebase Console → Cloud Messaging → Web Push certificates

# Razorpay (public key only)
REACT_APP_RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXX

# Google Maps
REACT_APP_GOOGLE_MAPS_KEY=AIzaSy...
