# ============================================================
# MK APP - Environment Variables
# Copy this to .env and fill in your values
# ============================================================

# Server
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000
FRONTEND_URLS=http://localhost:3000,http://localhost:3001

# MongoDB
MONGO_URI=mongodb://localhost:27017/mk-app
# Production: mongodb+srv://username:password@cluster.mongodb.net/mk-app

# Redis (optional but recommended for caching & sessions)
REDIS_URL=redis://localhost:6379
# Production: redis://username:password@your-redis-host:6379

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_mk2026
JWT_EXPIRE=30d
JWT_REFRESH_SECRET=your_refresh_token_secret_change_this
JWT_REFRESH_EXPIRE=90d

# Twilio (for OTP via SMS)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Razorpay (India payments)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# Stripe (International payments — UAE, Singapore, UK, US)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=MK App <noreply@mkapp.in>

# Firebase Admin SDK (push notifications)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY=your-firebase-private-key
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com

# WhatsApp Business API (Meta)
WHATSAPP_TOKEN=your_meta_whatsapp_access_token
WHATSAPP_PHONE_ID=your_whatsapp_phone_number_id
WHATSAPP_APP_SECRET=your_meta_app_secret
WHATSAPP_VERIFY_TOKEN=mk_wa_verify_2026

# Google Maps API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Agora (Video calls)
AGORA_APP_ID=your_agora_app_id
AGORA_APP_CERTIFICATE=your_agora_certificate

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads

# OTP Settings (dev mode — use static OTP)
OTP_STATIC=1234
OTP_EXPIRY=10

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=300

# App Settings
APP_NAME=MK App
APP_URL=https://mkapp.in
SUPPORT_EMAIL=support@mkapp.in
SUPPORT_PHONE=1800-123-4567

# AI Chatbot Booking Assistant (Anthropic Claude)
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Get from: https://console.anthropic.com

# Google OAuth (for social login)
GOOGLE_WEB_CLIENT_ID=xxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_IOS_CLIENT_ID=xxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_ANDROID_CLIENT_ID=xxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
