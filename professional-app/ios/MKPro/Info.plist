<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>

    <!-- ── App Identity ─────────────────────────────────── -->
    <key>CFBundleDisplayName</key>
    <string>MK Pro</string>
    <key>CFBundleIdentifier</key>
    <string>com.mkpro</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0.0</string>
    <key>CFBundleName</key>
    <string>MKPro</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundleDevelopmentRegion</key>
    <string>en</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>

    <!-- ── Orientation (portrait + landscape for job map) ── -->
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
    </array>

    <!-- ── Deep Links ────────────────────────────────────── -->
    <key>CFBundleURLTypes</key>
    <array>
        <dict>
            <key>CFBundleURLSchemes</key>
            <array><string>mkpro</string></array>
            <key>CFBundleURLName</key>
            <string>com.mkpro</string>
        </dict>
        <dict>
            <key>CFBundleURLSchemes</key>
            <array><string>$(REVERSED_CLIENT_ID)</string></array>
        </dict>
    </array>

    <!-- ── Google Maps ──────────────────────────────────── -->
    <key>GMSApiKey</key>
    <string>YOUR_GOOGLE_MAPS_API_KEY</string>

    <!-- ── Location (CRITICAL: background GPS for tracking) -->
    <key>NSLocationWhenInUseUsageDescription</key>
    <string>MK Pro needs your location to navigate to customer addresses.</string>
    <key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
    <string>MK Pro shares your live location with customers during active jobs so they can track your arrival.</string>
    <key>NSLocationAlwaysUsageDescription</key>
    <string>MK Pro tracks your location during active jobs to provide customers real-time updates.</string>

    <!-- ── Camera & Photos (ID verification + job photos) ── -->
    <key>NSCameraUsageDescription</key>
    <string>MK Pro needs camera access to take job completion photos and upload identity documents.</string>
    <key>NSPhotoLibraryUsageDescription</key>
    <string>MK Pro needs photo access to upload identity documents for verification.</string>
    <key>NSPhotoLibraryAddUsageDescription</key>
    <string>MK Pro needs to save job completion photos.</string>

    <!-- ── Face ID (for earnings withdrawal) ────────────── -->
    <key>NSFaceIDUsageDescription</key>
    <string>MK Pro uses Face ID to secure earnings withdrawals.</string>

    <!-- ── Network ──────────────────────────────────────── -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsArbitraryLoads</key>
        <false/>
        <key>NSExceptionDomains</key>
        <dict>
            <key>localhost</key>
            <dict>
                <key>NSExceptionAllowsInsecureHTTPLoads</key>
                <true/>
                <key>NSIncludesSubdomains</key>
                <true/>
            </dict>
        </dict>
    </dict>

    <!-- ── Background Modes (CRITICAL for GPS + push) ──── -->
    <key>UIBackgroundModes</key>
    <array>
        <string>fetch</string>
        <string>remote-notification</string>
        <string>location</string>          <!-- Live GPS sharing while on a job -->
        <string>processing</string>         <!-- Background sync -->
    </array>

    <!-- ── Status Bar ───────────────────────────────────── -->
    <key>UIStatusBarHidden</key>
    <false/>
    <key>UIViewControllerBasedStatusBarAppearance</key>
    <false/>

    <!-- ── Fonts ─────────────────────────────────────────── -->
    <key>UIAppFonts</key>
    <array>
        <string>Inter-Regular.ttf</string>
        <string>Inter-Medium.ttf</string>
        <string>Inter-SemiBold.ttf</string>
        <string>Inter-Bold.ttf</string>
        <string>Inter-ExtraBold.ttf</string>
        <string>Inter-Black.ttf</string>
    </array>

    <!-- ── Launch Screen ─────────────────────────────────── -->
    <key>UILaunchStoryboardName</key>
    <string>LaunchScreen</string>

    <!-- ── Hermes ─────────────────────────────────────────── -->
    <key>HermesEnabled</key>
    <true/>

</dict>
</plist>
